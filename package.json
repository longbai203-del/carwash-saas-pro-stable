{
  "name": "carwash-saas-pro",
  "version": "2.0.0",
  "description": "Enterprise SaaS for Carwash - Complete Business Management System",
  "main": "api/index.js",
  "type": "module",
  "scripts": {
    "start": "node api/index.js",
    "dev": "nodemon api/index.js",
    "dev:frontend": "npx serve frontend -l 3000",
    "build": "echo 'No build step required'",
    "setup": "node scripts/setup.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "test": "node scripts/test.js",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel",
    "lint": "eslint api/**/*.js frontend/**/*.js",
    "format": "prettier --write '**/*.{js,json,html,css}'"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "express": "^4.18.2",
    "dotenv": "^16.0.3",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "joi": "^17.9.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "vercel": "^32.0.0",
    "eslint": "^8.42.0",
    "prettier": "^2.8.8"
  },
  "author": "Carwash Pro Team",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "carwash",
    "saas",
    "erp",
    "pos",
    "crm",
    "inventory",
    "management",
    "business"
  ]
}