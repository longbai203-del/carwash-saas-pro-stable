{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "carwash-saas-pro-stable",
  "cleanUrls": true,
  "trailingSlash": false,
  "framework": null,
  "functions": {
    "api/index.js": {
      "runtime": "@vercel/node@22",
      "memory": 1024,
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/module-map.json",  "destination": "/frontend/module-map.json" },
    { "source": "/js/(.*)",          "destination": "/frontend/js/$1" },
    { "source": "/css/(.*)",         "destination": "/frontend/css/$1" },
    { "source": "/components/(.*)",  "destination": "/frontend/components/$1" },
    { "source": "/modules/(.*)",     "destination": "/frontend/modules/$1" },
    { "source": "/assets/(.*)",      "destination": "/frontend/assets/$1" },
    { "source": "/(.*)\\.js",        "destination": "/frontend/$1.js" },
    { "source": "/(.*)\\.css",       "destination": "/frontend/$1.css" },
    { "source": "/",                 "destination": "/frontend/index.html" },
    {
      "source": "/((?!api/|_vercel|.*\\.[a-zA-Z0-9]+$).*)",
      "destination": "/frontend/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",      "value": "*" },
        { "key": "Access-Control-Allow-Methods",     "value": "GET, POST, PUT, PATCH, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers",     "value": "Authorization, Content-Type, X-Client-Info, apikey" },
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Max-Age",           "value": "86400" },
        { "key": "Cache-Control",                    "value": "no-store" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options",        "value": "DENY" }
      ]
    }
  ]
}