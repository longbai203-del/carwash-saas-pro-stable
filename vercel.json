{
  "version": 2,
  "routes": [
    {
      "src": "/js/(.*)",
      "headers": {
        "Content-Type": "application/javascript"
      },
      "dest": "/js/$1"
    },
    {
      "src": "/modules/(.*)/(.*)",
      "headers": {
        "Content-Type": "application/javascript"
      },
      "dest": "/modules/$1/$2"
    },
    {
      "src": "/services/(.*)",
      "headers": {
        "Content-Type": "application/javascript"
      },
      "dest": "/services/$1"
    },
    {
      "src": "/components/(.*)",
      "headers": {
        "Content-Type": "application/javascript"
      },
      "dest": "/components/$1"
    },
    {
      "src": "/css/(.*)",
      "headers": {
        "Content-Type": "text/css"
      },
      "dest": "/css/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "functions": {
    "api/nvr-webhook.js": {
      "maxDuration": 10
    }
  }
}