{
    "version": 2,
    "name": "carwash-saas-pro-stable",
    "builds": [
      {
        "src": "api/index.js",
        "use": "@vercel/node"
      }
    ],
    "routes": [
      {
        "src": "/api/(.*)",
        "dest": "/api/index.js"
      },
      {
        "src": "/js/app.js",
        "dest": "/frontend/js/app.js"
      },
      {
        "src": "/js/core/(.*)",
        "dest": "/frontend/js/core/$1"
      },
      {
        "src": "/js/api/(.*)",
        "dest": "/frontend/js/api/$1"
      },
      {
        "src": "/js/services/(.*)",
        "dest": "/frontend/js/services/$1"
      },
      {
        "src": "/js/(.*)",
        "dest": "/frontend/js/$1"
      },
      {
        "src": "/css/(.*)",
        "dest": "/frontend/css/$1"
      },
      {
        "src": "/components/(.*)",
        "dest": "/frontend/components/$1"
      },
      {
        "src": "/modules/(.*)",
        "dest": "/frontend/modules/$1"
      },
      {
        "src": "/assets/(.*)",
        "dest": "/frontend/assets/$1"
      },
      {
        "src": "/module-map.json",
        "dest": "/frontend/module-map.json"
      },
      {
        "src": "/favicon.ico",
        "dest": "/frontend/favicon.ico"
      },
      {
        "src": "/",
        "dest": "/frontend/index.html"
      }
    ],
