{
  "version": 2,
  "name": "carwash-saas-pro",
  "outputDirectory": "frontend",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/modules/(.*)",
      "dest": "/frontend/modules/"
    },
    {
      "src": "/css/(.*)",
      "dest": "/frontend/css/"
    },
    {
      "src": "/js/(.*)",
      "dest": "/frontend/js/"
    },
    {
      "src": "/components/(.*)",
      "dest": "/frontend/components/"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/assets/"
    },
    {
      "src": "/favicon.ico",
      "dest": "/frontend/favicon.ico"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ],
 "env": {
  "SUPABASE_URL": "@supabase_url",
  "SUPABASE_ANON_KEY": "@supabase_anon_key",
  "SUPABASE_SERVICE_KEY": "@supabase_service_key",
  "JWT_SECRET": "@jwt_secret",
  "NODE_ENV": "production"
},
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  }
}
