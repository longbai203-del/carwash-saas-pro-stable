# ============================================================
# CarWash SaaS Pro - 环境变量配置
# ============================================================

# ===== Supabase 配置 =====
# Supabase 项目 URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key（前端使用）
SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key（后端使用，有完整权限）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== JWT 配置 =====
# JWT 签名密钥（用于自定义 token）
JWT_SECRET=your-jwt-secret-key

# ===== 应用配置 =====
# 应用名称
APP_NAME=CarWash Pro

# 应用版本
APP_VERSION=3.0.0

# 调试模式 (true/false)
DEBUG=true

# 日志级别 (debug/info/warn/error/none)
LOG_LEVEL=info

# ===== 外部服务 =====
# NVR Webhook 密钥
NVR_WEBHOOK_SECRET=your-nvr-webhook-secret

# 支付回调密钥
PAYMENT_WEBHOOK_SECRET=your-payment-webhook-secret

# ===== 其他 =====
# 默认门店 ID
DEFAULT_STORE_ID=

# 默认租户 ID
DEFAULT_TENANT_ID=